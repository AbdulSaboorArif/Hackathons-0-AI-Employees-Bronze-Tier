# Security Configuration

# Never commit sensitive data
.env
*.env
.env.*

# Credentials and secrets
credentials.json
token.json
secrets/
*.key
*.pem
*.p12

# Session data
whatsapp_session/
browser_session/
*.session

# Logs with potentially sensitive data
*.log
logs/
Logs/*.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Obsidian
.obsidian/
.trash/

# Temporary files
*.tmp
*.temp
~*

# Backup files
*.bak
*.backup

# Database files (if added later)
*.db
*.sqlite
*.sqlite3

# Node modules (for MCP servers)
node_modules/
package-lock.json

# Build artifacts
dist/
build/
*.egg-info/
